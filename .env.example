# Telegram settings for YT Harvester.
# Copy this file to .env for local source runs, or edit
# ~/.config/yt-harvester/.env after installing the deb package.

BOT_TOKEN=your-telegram-bot-token
CHANNEL_ID=your-telegram-channel-id

# Optional SOCKS5 proxy for Telegram curl requests:
# PROXY_URL=127.0.0.1:9050
